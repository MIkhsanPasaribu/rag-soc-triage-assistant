# ==========================================
# Konfigurasi LLM (Groq)
# ==========================================
GROQ_API_KEY=gsk_your_groq_api_key_here
LLM_MODEL=llama3-70b-8192

# ==========================================
# Konfigurasi Tracing (LangSmith)
# ==========================================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=ls__your_langsmith_api_key_here
LANGCHAIN_PROJECT=rag-soc-triage-assistant

# ==========================================
# Konfigurasi Vector Store (Chroma)
# ==========================================
CHROMA_PERSIST_DIRECTORY=./data/vector_store
